# === Delivery — variables d'environnement (exemple) ===
# Copier en .env.local et remplir. NE JAMAIS committer les vraies valeurs.

# --- Supabase (DB + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # côté serveur uniquement

# --- Google OAuth (Auth + scopes Gmail/Drive/Docs) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Scopes requis : openid email profile
#   https://www.googleapis.com/auth/gmail.compose
#   https://www.googleapis.com/auth/drive.file
#   https://www.googleapis.com/auth/documents

# --- Cible / config utilisateur (peut aussi vivre en base, cf. table settings) ---
DRIVE_FOLDER_ID=                    # dossier Drive des rapports longs
REPORT_EMAIL_TO=assist-direction@mada-digital.net
REPORT_EMAIL_CC=direction@mada-digital.net
REPORT_THREAD_SUBJECT=Rapport de stage

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_USERNAME=

# --- IA (choisir le provider) ---
LLM_PROVIDER=gemini                 # gemini | groq
GEMINI_API_KEY=                     # https://aistudio.google.com/apikey  (gratuit)
GROQ_API_KEY=                       # alternative

# --- Cron (protège les routes /api/cron/*) ---
CRON_SECRET=

# --- Divers ---
APP_TIMEZONE=Indian/Antananarivo    # fuseau pour libellés de semaine / horaires
